# OpenAI 配置
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# 聊天模型提供方
CHAT_PROVIDER=ollama

# 备用 API 配置 (可选)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# Ollama / MLX 聊天模型配置
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_QWEN_MODEL=qwen2.5:7b-instruct
OLLAMA_QWEN_URL=
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:4b
MLX_MODEL_PATH=
MLX_MAX_TOKENS=2000

# 应用配置
APP_NAME=智能教育平台 AI 服务
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# 服务器配置
HOST=0.0.0.0
PORT=8000
WORKERS=1

# 向量数据库配置
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=edu_knowledge

# 知识库配置
MAX_UPLOAD_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,txt,docx,md
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# 缓存配置
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# MongoDB 对话存储配置
MONGODB_ENABLED=true
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=ai_service
MONGODB_CHAT_COLLECTION=rag_chat_messages
MONGODB_HISTORY_LIMIT=40

# 限流配置
RATE_LIMIT_PER_MINUTE=60
